# SAP WebGUI 连接
SAP_URL=https://your-sap-host:8443/sap/bc/gui/sap/its/webgui?sap-client=110&sap-language=ZH
SAP_CLIENT=110
SAP_LANG=ZH

# Mify API（动态获取 SAP 凭证）
MIFY_TOKEN=app-your-token-here
MIFY_JOB_ID=your-job-id

# Toolskit API（SRM 数据操作）
TOOLSKIT_BASE_URL=https://your-toolskit-host.example.com
TOOLSKIT_TOKEN=

# SRM Web Portal
SRM_BASE_URL=https://your-srm-host.example.com
SRM_COMPANY_CODE=1000:Example Company
SRM_PURCHASING_ORG=2000:Example Purchasing Org

# 发票默认值（按实际业务配置）
DEFAULT_INVOICE_CODE=
DEFAULT_INVOICE_NO=

# AI 兜底（Anthropic API，可选）
ANTHROPIC_API_KEY=

# 浏览器配置
HEADLESS=false
BROWSER_SLOW_MO=0
