{
  "name": "sap-playwright-agent",
  "version": "0.1.0",
  "description": "AI + Playwright driven SAP Web GUI automation tool",
  "type": "module",
  "bin": {
    "sap-auto": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "record-flow": "tsx src/recording/cli.ts record-flow",
    "compile-recording": "tsx src/recording/cli.ts compile-recording",
    "promote-recording": "tsx src/recording/cli.ts promote-recording",
    "validate-flows": "tsx src/engine/flow-capabilities-cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.48.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
